# InsForge project URL (OSS host), e.g. https://<appkey>.<region>.insforge.app
VITE_INSFORGE_URL=

# Anonymous JWT for browser clients. Generate with:
#   curl -sS -X POST "$VITE_INSFORGE_URL/api/auth/tokens/anon" \
#     -H "Authorization: Bearer <your-project-api-key-ik_...>"
# Or use the InsForge dashboard.
VITE_INSFORGE_ANON_KEY=
